{
  "name": "auto-review-fix-sandbox",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "jj-status": "jj status",
    "jj-log": "jj log",
    "jj-diff": "jj diff",
    "jj-describe": "jj describe",
    "jj-new": "jj new",
    "jj-start-change": "bash .claude/scripts/jj-start-change.sh",
    "jj-squash": "jj squash",
    "jj-bookmark": "jj bookmark",
    "jj-rebase": "jj rebase",
    "jj-edit": "jj edit",
    "jj-abandon": "jj abandon",
    "jj-restore": "jj restore",
    "jj-file-show": "jj file show",
    "jj-fetch": "jj git fetch",
    "jj-push": "bash .claude/scripts/jj-push-safe.sh",
    "gh-repo": "gh repo",
    "gh-pr": "gh pr",
    "gh-run": "gh run",
    "gh-api": "bash .claude/scripts/gh-api-safe.sh",
    "gh-secret": "gh secret",
    "typecheck": "mypy --config-file ai-review-fixer/pyproject.toml ai-review-fixer/",
    "daemon": "python ai-review-fixer/orchestrator.py",
    "daemon:loop": "python ai-review-fixer/orchestrator.py --loop",
    "py-lint": "ruff check ai-review-fixer/ --exclude ai-review-fixer/tests",
    "py-lint:fix": "ruff check ai-review-fixer/ --exclude ai-review-fixer/tests --fix",
    "py-lint:all": "ruff check ai-review-fixer/ scripts/",
    "py-lint:all:fix": "ruff check ai-review-fixer/ scripts/ --fix",
    "py-test": "pytest ai-review-fixer/tests -m \"not e2e\" -v",
    "py-test:e2e": "pytest ai-review-fixer/tests/e2e/ -m e2e -v -s -r s",
    "py-test:cov": "pytest ai-review-fixer/tests -m \"not e2e\" --cov=ai-review-fixer --cov-report=term-missing --cov-fail-under=80",
    "py-install-dev": "pip install -r ai-review-fixer/requirements.txt -r ai-review-fixer/requirements-dev.txt",
    "gh-reviews": "python scripts/fetch_pr_reviews.py --",
    "gh-unresolved": "python scripts/list_unresolved.py --"
  }
}
